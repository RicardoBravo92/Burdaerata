generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name  String
  first_name String
  last_name  String
  avatar_url String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  gamesHosted  Game[]        @relation("HostPlayer")
  gamePlayers  GamePlayer[]
  playerCards  PlayerCard[]
  roundAnswers RoundAnswer[]
  roundsJudged Round[]       @relation("JudgeUser")

  @@map("users")
}

model Game {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String    @unique
  host_player_id String    @db.Uuid
  status         String?   @default("waiting")
  max_players    Int?      @default(8)
  public         Boolean?  @default(true)
  score_to_win   Int?
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  host        User         @relation("HostPlayer", fields: [host_player_id], references: [id])
  players     GamePlayer[]
  playerCards PlayerCard[]
  rounds      Round[]

  @@map("games")
}

model GamePlayer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_id    String    @db.Uuid
  user_id    String    @db.Uuid
  score      Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  game    Game @relation(fields: [game_id], references: [id])
  profile User @relation(fields: [user_id], references: [id])

  @@map("game_players")
}

model PlayerCard {
  id         Int      @id @default(autoincrement())
  user_id    String?  @db.Uuid
  game_id    String?  @db.Uuid
  cards      String[]
  created_at DateTime @default(now()) @db.Timestamptz(6)

  game Game? @relation(fields: [game_id], references: [id])
  user User? @relation(fields: [user_id], references: [id])

  @@map("player_cards")
}

model Round {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_id           String    @db.Uuid
  round_number      Int
  question_card_id  String
  judge_user_id     String    @db.Uuid
  status            String?   @default("submitting")
  winning_answer_id String?   @db.Uuid
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  game           Game          @relation(fields: [game_id], references: [id])
  judge          User          @relation("JudgeUser", fields: [judge_user_id], references: [id])
  winning_answer RoundAnswer?  @relation("WinningAnswer", fields: [winning_answer_id], references: [id])
  answers        RoundAnswer[] @relation("RoundRelation")

  @@map("rounds")
}

model RoundAnswer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  round_id   String    @db.Uuid
  user_id    String    @db.Uuid
  cards_used String[]
  final_text String?
  is_winner  Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  round           Round   @relation("RoundRelation", fields: [round_id], references: [id])
  user            User    @relation(fields: [user_id], references: [id])
  winningInRounds Round[] @relation("WinningAnswer")

  @@map("round_answers")
}
